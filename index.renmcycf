<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>RENMCYCF · Registro Nacional</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = { 
            theme: { 
                extend: { 
                    colors: { 
                        forenseNavy: '#0a1128', 
                        forenseGold: '#d4af37', 
                        forenseBlue: '#1e3a8a',
                        forenseLight: '#f8fafc' 
                    }, 
                    fontFamily: { 
                        sans: ['Inter', 'sans-serif'], 
                        title: ['Montserrat', 'sans-serif'] 
                    } 
                } 
            } 
        }
    </script>
    <style>
        body { background-color: #f8fafc; color: #334155; scroll-behavior: smooth; }
        .hero-pattern { 
            background-color: #0a1128; 
            background-image: radial-gradient(circle at 20% 30%, rgba(30, 58, 138, 0.4) 0%, transparent 50%), 
                              radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.15) 0%, transparent 50%);
        }
        
        .logo-arcada { 
            background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%); 
            border-radius: 100px 100px 12px 12px; 
            border: 1px solid #cbd5e1; 
            border-bottom: 4px solid #d4af37; 
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.3), inset 0 2px 5px rgba(255,255,255,1); 
            position: relative; 
            display: flex; align-items: center; justify-content: center;
        }
        .logo-arcada::before { 
            content: ''; position: absolute; top: 5px; left: 5px; right: 5px; bottom: 5px; 
            border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 95px 95px 8px 8px; pointer-events: none; 
        }

        /* Estilos del Formulario */
        .form-input {
            width: 100%; padding: 12px 16px; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 8px;
            font-size: 0.875rem; color: #1e293b; transition: all 0.3s; outline: none;
        }
        .form-input:focus { border-color: #1e3a8a; box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1); }
        .form-label { display: block; font-size: 0.75rem; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
        
        .file-upload-box {
            border: 2px dashed #cbd5e1; border-radius: 12px; padding: 20px; text-align: center;
            background: #f8fafc; cursor: pointer; transition: all 0.3s;
        }
        .file-upload-box:hover { border-color: #1e3a8a; background: #eff6ff; }
        .file-upload-box input[type="file"] { display: none; }

        .cat-card { transition: all 0.3s; border-top: 4px solid transparent; }
        .cat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
        .cat-a1:hover { border-top-color: #d4af37; }
        .cat-a2:hover { border-top-color: #3b82f6; }
        .cat-a3:hover { border-top-color: #10b981; }

    </style>
</head>
<body class="min-h-screen flex flex-col font-sans">

    <!-- TEXTO INSTITUCIONAL COMPLETO ARRIBA DE TODO -->
    <div class="bg-forenseNavy text-white text-[9px] md:text-xs py-2.5 px-4 text-center font-bold tracking-[0.15em] md:tracking-[0.2em] uppercase z-50 shadow-md">
        REGISTRO NACIONAL DE MATRICULADOS EN CRIMINALÍSTICA Y CIENCIAS FORENSES
    </div>

    <nav class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm h-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex items-center justify-between">
            <div class="flex items-center gap-4 cursor-pointer h-full" onclick="window.scrollTo(0,0)">
                <div class="logo-arcada w-12 h-16 md:w-16 md:h-20 shrink-0 relative mt-2 z-10 transition-all">
                    <i data-lucide="fingerprint" class="w-6 h-6 md:w-8 md:h-8 text-forenseNavy relative z-10"></i>
                </div>
                <div class="leading-tight">
                    <span class="font-title font-black text-xl md:text-2xl tracking-tight block text-forenseNavy">REMCYCJ</span>
                    <span class="text-[8px] md:text-[10px] text-forenseGold font-bold uppercase tracking-widest">Plataforma Oficial</span>
                </div>
            </div>
            
            <div class="hidden md:flex items-center gap-8 text-[11px] font-bold text-forenseNavy uppercase tracking-widest">
                <a href="#categorias" class="hover:text-forenseGold transition-colors">Categorías</a>
                <a href="#ecosistema" class="hover:text-forenseGold transition-colors">Tecnología</a>
                <a href="#inscripcion" class="bg-forenseGold text-white hover:bg-yellow-600 transition-all px-6 py-2.5 rounded shadow-md">
                    Iniciar Trámite
                </a>
            </div>
        </div>
    </nav>

    <header class="hero-pattern py-20 md:py-32 px-4 relative flex flex-col items-center justify-center text-center border-b-4 border-forenseGold">
        <div class="relative max-w-4xl mx-auto z-10">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-forenseGold text-[10px] md:text-xs font-bold uppercase tracking-widest mb-8 border border-forenseGold/30 backdrop-blur-sm">
                <i data-lucide="shield-check" class="w-4 h-4"></i> Inscripciones Abiertas 2026
            </div>
            
            <h1 class="font-title text-4xl md:text-5xl lg:text-6xl font-black mb-6 text-white leading-tight uppercase drop-shadow-lg">
                Respaldo Legal para tu <br><span class="text-forenseGold">Práctica Forense</span>
            </h1>
            
            <p class="text-slate-300 mb-10 text-sm md:text-base max-w-2xl mx-auto font-light leading-relaxed tracking-wide">
                El único padrón nacional centralizado con tecnología Blockchain. Obtén tu credencial digital, valída tus competencias y destaca en el ámbito judicial y criminalístico.
            </p>
            
            <a href="#inscripcion" class="inline-block bg-forenseGold text-forenseNavy font-black uppercase tracking-widest text-sm px-8 py-4 rounded-lg shadow-[0_0_20px_rgba(212,175,55,0.4)] hover:scale-105 transition-transform">
                Comenzar Inscripción
            </a>
        </div>
    </header>

    <!-- SECCIÓN CATEGORÍAS (NUEVO) -->
    <section id="categorias" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="font-title text-3xl font-black text-forenseNavy mb-4 uppercase tracking-tight">Estructura del Padrón</h2>
                <div class="w-16 h-[3px] bg-forenseGold mx-auto mb-4"></div>
                <p class="text-slate-500 text-sm max-w-2xl mx-auto">El registro divide a los profesionales en tres categorías oficiales según su nivel de titulación y alcance legal.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="cat-card cat-a1 bg-slate-50 rounded-xl p-8 border border-slate-200">
                    <div class="w-14 h-14 bg-forenseGold/20 text-forenseGold rounded-full flex items-center justify-center mb-6">
                        <span class="font-black text-xl">A1</span>
                    </div>
                    <h3 class="font-bold text-xl text-forenseNavy mb-3">Licenciaturas y Títulos Universitarios</h3>
                    <p class="text-sm text-slate-600 leading-relaxed mb-4">Reservado para profesionales con grado universitario completo.</p>
                    <ul class="text-xs text-slate-500 space-y-2 font-medium">
                        <li>• Lic. en Criminalística</li>
                        <li>• Médicos Legistas</li>
                        <li>• Abogados Penalistas</li>
                    </ul>
                </div>

                <div class="cat-card cat-a2 bg-slate-50 rounded-xl p-8 border border-slate-200">
                    <div class="w-14 h-14 bg-blue-500/20 text-blue-600 rounded-full flex items-center justify-center mb-6">
                        <span class="font-black text-xl">A2</span>
                    </div>
                    <h3 class="font-bold text-xl text-forenseNavy mb-3">Técnicos y Títulos Terciarios</h3>
                    <p class="text-sm text-slate-600 leading-relaxed mb-4">Para egresados de tecnicaturas superiores oficiales.</p>
                    <ul class="text-xs text-slate-500 space-y-2 font-medium">
                        <li>• Técnicos Evisceradores</li>
                        <li>• Técnicos en Balística</li>
                        <li>• Peritos Papilóscopos</li>
                    </ul>
                </div>

                <div class="cat-card cat-a3 bg-slate-50 rounded-xl p-8 border border-slate-200">
                    <div class="w-14 h-14 bg-emerald-500/20 text-emerald-600 rounded-full flex items-center justify-center mb-6">
                        <span class="font-black text-xl">A3</span>
                    </div>
                    <h3 class="font-bold text-xl text-forenseNavy mb-3">Auxiliares y Formación Continua</h3>
                    <p class="text-sm text-slate-600 leading-relaxed mb-4">Para personal de apoyo, instructores y diplomados.</p>
                    <ul class="text-xs text-slate-500 space-y-2 font-medium">
                        <li>• Auxiliares Forenses</li>
                        <li>• Fotógrafos Periciales</li>
                        <li>• Paramédicos Tácticos</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- FORMULARIO DE ADHESIÓN (NUEVO) -->
    <section id="inscripcion" class="py-20 bg-slate-100 border-y border-slate-200 relative overflow-hidden">
        <!-- Decoración de fondo -->
        <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-forenseGold/5 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-96 h-96 bg-forenseBlue/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="max-w-4xl mx-auto px-4 relative z-10">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-200">
                <div class="bg-forenseNavy p-8 text-center text-white border-b-4 border-forenseGold">
                    <h2 class="font-title text-2xl md:text-3xl font-black uppercase tracking-tight mb-2">Formulario de Inscripción</h2>
                    <p class="text-sm text-slate-300 font-light">Complete sus datos para iniciar el trámite de validación y matriculación.</p>
                </div>

                <form id="form-publico-adhesion" class="p-8 md:p-12 space-y-8" onsubmit="enviarTramiteSimulado(event)">
                    
                    <!-- 1. Datos Personales -->
                    <div>
                        <h3 class="text-lg font-bold text-forenseNavy mb-4 flex items-center gap-2 border-b pb-2">
                            <i data-lucide="user" class="text-forenseGold w-5 h-5"></i> 1. Datos Personales
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div><label class="form-label">Nombres Completos</label><input type="text" class="form-input" required placeholder="Ej: Juan Carlos"></div>
                            <div><label class="form-label">Apellidos</label><input type="text" class="form-input" required placeholder="Ej: Perez"></div>
                            
                            <div><label class="form-label">DNI</label><input type="text" class="form-input font-mono" required placeholder="Sin puntos ni espacios"></div>
                            <div><label class="form-label">Año de Nacimiento</label><input type="number" class="form-input" required placeholder="Ej: 1985"></div>
                            
                            <div><label class="form-label">Correo Electrónico</label><input type="email" class="form-input" required placeholder="correo@ejemplo.com"></div>
                            <div><label class="form-label">Teléfono Móvil</label><input type="text" class="form-input" required placeholder="Código de área + número"></div>
                            
                            <div class="md:col-span-2"><label class="form-label">Domicilio Completo</label><input type="text" class="form-input" required placeholder="Calle, Número, Ciudad, Provincia"></div>
                        </div>
                    </div>

                    <!-- 2. Datos Profesionales -->
                    <div>
                        <h3 class="text-lg font-bold text-forenseNavy mb-4 flex items-center gap-2 border-b pb-2">
                            <i data-lucide="graduation-cap" class="text-forenseGold w-5 h-5"></i> 2. Formación Profesional
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-end">
                            <div>
                                <label class="form-label">Profesión / Título a Registrar</label>
                                <select id="pub-profesion" class="form-input font-semibold" required onchange="asignarCategoriaPublica()">
                                    <option value="">Seleccione su título...</option>
                                    <optgroup label="A1: Universitarios">
                                        <option value="A1">Licenciado/a en Criminalística</option>
                                        <option value="A1">Médico/a Legista</option>
                                        <option value="A1">Abogado/a Penalista</option>
                                    </optgroup>
                                    <optgroup label="A2: Técnicos/Terciarios">
                                        <option value="A2">Técnico/a Eviscerador/a</option>
                                        <option value="A2">Técnico/a en Balística</option>
                                        <option value="A2">Perito Papilóscopo</option>
                                    </optgroup>
                                    <optgroup label="A3: Auxiliares">
                                        <option value="A3">Auxiliar Forense</option>
                                        <option value="A3">Fotógrafo/a Pericial</option>
                                        <option value="A3">Instructor/a Forense</option>
                                    </optgroup>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Categoría Asignada por Sistema</label>
                                <div id="display-categoria" class="form-input bg-slate-100 text-slate-400 font-bold flex items-center justify-between">
                                    <span>Esperando selección...</span>
                                </div>
                                <input type="hidden" id="hidden-categoria" required>
                            </div>
                        </div>
                    </div>

                    <!-- 3. Documentación -->
                    <div>
                        <h3 class="text-lg font-bold text-forenseNavy mb-4 flex items-center gap-2 border-b pb-2">
                            <i data-lucide="file-check" class="text-forenseGold w-5 h-5"></i> 3. Documentación Respaldatoria
                        </h3>
                        <p class="text-xs text-slate-500 mb-4">Adjunte imágenes claras y legibles (JPG, PNG). El peso máximo por archivo es 5MB.</p>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                            <label class="file-upload-box group">
                                <i data-lucide="image" class="w-8 h-8 mx-auto text-slate-400 group-hover:text-forenseBlue mb-2 transition-colors"></i>
                                <span class="block text-xs font-bold text-slate-700">DNI Frente</span>
                                <span class="block text-[10px] text-slate-500 mt-1" id="file-name-frente">Clic para subir</span>
                                <input type="file" required accept="image/*" onchange="actualizarNombreArchivo(this, 'file-name-frente')">
                            </label>
                            
                            <label class="file-upload-box group">
                                <i data-lucide="image" class="w-8 h-8 mx-auto text-slate-400 group-hover:text-forenseBlue mb-2 transition-colors"></i>
                                <span class="block text-xs font-bold text-slate-700">DNI Dorso</span>
                                <span class="block text-[10px] text-slate-500 mt-1" id="file-name-dorso">Clic para subir</span>
                                <input type="file" required accept="image/*" onchange="actualizarNombreArchivo(this, 'file-name-dorso')">
                            </label>

                            <label class="file-upload-box group border-forenseGold/30 bg-yellow-50/30">
                                <i data-lucide="award" class="w-8 h-8 mx-auto text-forenseGold mb-2"></i>
                                <span class="block text-xs font-bold text-slate-700">Diploma / Certificado</span>
                                <span class="block text-[10px] text-slate-500 mt-1" id="file-name-diploma">Archivo a intervenir</span>
                                <input type="file" required accept="image/*" onchange="actualizarNombreArchivo(this, 'file-name-diploma')">
                            </label>
                        </div>
                        <p class="text-[10px] text-slate-400 mt-3 text-center">Nota: El Diploma subido será evaluado por los peritos titulares e intervenido con el sello oficial de inscripción en caso de ser aprobado.</p>
                    </div>

                    <!-- Submit -->
                    <div class="pt-6 border-t border-slate-200">
                        <label class="flex items-start gap-3 mb-6 cursor-pointer">
                            <input type="checkbox" required class="mt-1 w-4 h-4 accent-forenseBlue">
                            <span class="text-xs text-slate-600 leading-relaxed">Declaro bajo juramento que los datos y documentos proporcionados son auténticos. Entiendo que la adulteración de los mismos constituye un delito y facultará al REMCYCJ a rechazar o dar de baja la matrícula de forma permanente.</span>
                        </label>
                        
                        <button type="submit" id="btn-submit-tramite" class="w-full bg-forenseNavy hover:bg-slate-800 text-white font-black uppercase tracking-widest py-4 rounded-xl shadow-lg transition-all flex items-center justify-center gap-2">
                            ENVIAR SOLICITUD AL REGISTRO
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </section>

    <!-- SECCIÓN ECOSISTEMA (Mantenida y Adaptada) -->
    <section id="ecosistema" class="py-24 bg-forenseNavy text-white relative overflow-hidden border-t border-forenseGold/20">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
            <div class="relative z-10">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-forenseGold/10 text-forenseGold text-[10px] font-bold uppercase tracking-widest mb-6 border border-forenseGold/30"><i data-lucide="link" class="w-3 h-3"></i> Trazabilidad Inmutable</div>
                <h2 class="font-title text-3xl md:text-4xl font-black mb-6 uppercase tracking-tight leading-tight">Infraestructura <br><span class="text-forenseGold">Blockchain</span></h2>
                <p class="text-slate-300 text-sm leading-relaxed mb-10 font-light">El REMCYCJ emite documentación de última generación. Cada profesional matriculado accede a un ecosistema diseñado para evitar fraudes y agilizar la validación de sus pericias ante entidades judiciales.</p>
                <div class="space-y-8">
                    <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 text-forenseGold"><i data-lucide="qr-code" class="w-6 h-6"></i></div><div><h4 class="font-title font-bold text-white uppercase text-xs tracking-wider mb-1.5">Carnet con QR Público</h4><p class="text-xs text-slate-400 leading-relaxed font-light">Al escanear el reverso de su credencial, cualquier autoridad verificará su estado activo en tiempo real.</p></div></div>
                    <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 text-forenseGold"><i data-lucide="stamp" class="w-6 h-6"></i></div><div><h4 class="font-title font-bold text-white uppercase text-xs tracking-wider mb-1.5">Intervención Digital</h4><p class="text-xs text-slate-400 leading-relaxed font-light">Sus diplomas originales son sellados criptográficamente para certificar la inscripción en el registro.</p></div></div>
                    <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 text-forenseGold"><i data-lucide="smartphone" class="w-6 h-6"></i></div><div><h4 class="font-title font-bold text-white uppercase text-xs tracking-wider mb-1.5">Billetera Forense (PWA)</h4><p class="text-xs text-slate-400 leading-relaxed font-light">Acceso 24/7 a sus documentos desde el teléfono móvil para presentarlos en fiscalías o juzgados.</p></div></div>
                </div>
            </div>
            <!-- Elemento visual representativo de la billetera -->
            <div class="relative w-full h-[400px] flex items-center justify-center">
                <div class="absolute w-[260px] h-[400px] bg-slate-900 border-[6px] border-slate-800 rounded-3xl shadow-[0_0_50px_rgba(212,175,55,0.2)] overflow-hidden flex flex-col">
                    <div class="h-16 bg-forenseNavy flex items-center justify-center border-b border-white/10">
                        <span class="text-xs font-bold text-white uppercase tracking-widest">Wallet REMCYCJ</span>
                    </div>
                    <div class="flex-1 p-4 bg-slate-100 flex flex-col gap-4">
                        <div class="h-40 bg-white rounded-xl shadow-sm border border-slate-200 p-3 flex flex-col justify-between">
                            <div class="flex justify-between items-start">
                                <div class="w-10 h-10 bg-slate-200 rounded-full"></div>
                                <span class="bg-emerald-100 text-emerald-600 text-[8px] font-bold px-2 py-1 rounded">ACTIVO</span>
                            </div>
                            <div>
                                <div class="h-3 w-24 bg-slate-200 rounded mb-1"></div>
                                <div class="h-2 w-16 bg-slate-200 rounded"></div>
                            </div>
                        </div>
                        <div class="h-20 bg-white rounded-xl shadow-sm border border-slate-200 flex items-center justify-center">
                            <i data-lucide="qr-code" class="w-10 h-10 text-slate-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-[#050914] text-slate-400 py-12 text-center border-t border-slate-800">
        <div class="max-w-4xl mx-auto px-4">
            <div class="flex items-center justify-center gap-3 text-white mb-6">
                <i data-lucide="fingerprint" class="w-6 h-6 text-forenseGold"></i>
                <span class="font-title font-black text-xl tracking-widest">REMCYCJ</span>
            </div>
            <p class="text-xs text-slate-500 max-w-md mx-auto leading-relaxed mb-6 font-light">REGISTRO NACIONAL DE MATRICULADOS EN CRIMINALÍSTICA Y CIENCIAS FORENSES. Plataforma auditada y asegurada criptográficamente.</p>
            <div class="text-[10px] text-slate-600 font-sans tracking-widest uppercase">Tecnología provista por ASARI SaaS © 2026</div>
        </div>
    </footer>

    <script>
        lucide.createIcons();

        // Actualizar nombre visual de los archivos subidos
        function actualizarNombreArchivo(input, labelId) {
            const label = document.getElementById(labelId);
            if (input.files && input.files[0]) {
                label.innerText = input.files[0].name;
                label.classList.add('text-forenseBlue', 'font-bold');
            } else {
                label.innerText = 'Clic para subir';
                label.classList.remove('text-forenseBlue', 'font-bold');
            }
        }

        // Lógica de Categorías Dinámicas
        function asignarCategoriaPublica() {
            const select = document.getElementById('pub-profesion');
            const display = document.getElementById('display-categoria');
            const hidden = document.getElementById('hidden-categoria');
            const val = select.value;
            
            if (val === 'A1') {
                display.innerHTML = `<span class="text-forenseGold font-black text-lg">A1</span> <span class="text-xs uppercase">Universitario</span>`;
                display.className = "form-input bg-yellow-50 border-forenseGold text-forenseGold font-bold flex items-center justify-between";
                hidden.value = 'A1';
            } else if (val === 'A2') {
                display.innerHTML = `<span class="text-blue-600 font-black text-lg">A2</span> <span class="text-xs uppercase">Técnico</span>`;
                display.className = "form-input bg-blue-50 border-blue-500 text-blue-600 font-bold flex items-center justify-between";
                hidden.value = 'A2';
            } else if (val === 'A3') {
                display.innerHTML = `<span class="text-emerald-600 font-black text-lg">A3</span> <span class="text-xs uppercase">Auxiliar</span>`;
                display.className = "form-input bg-emerald-50 border-emerald-500 text-emerald-600 font-bold flex items-center justify-between";
                hidden.value = 'A3';
            } else {
                display.innerHTML = `<span>Esperando selección...</span>`;
                display.className = "form-input bg-slate-100 text-slate-400 font-bold flex items-center justify-between";
                hidden.value = '';
            }
        }

        // Simulación de Envío a Supabase (Para conectar luego)
        function enviarTramiteSimulado(e) {
            e.preventDefault();
            const btn = document.getElementById('btn-submit-tramite');
            const originalHTML = btn.innerHTML;
            
            btn.innerHTML = `<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i> PROCESANDO ARCHIVOS...`;
            btn.disabled = true;
            btn.classList.add('opacity-80', 'cursor-not-allowed');
            lucide.createIcons();

            // Simular tiempo de subida de imágenes y Base de Datos
            setTimeout(() => {
                btn.innerHTML = `<i data-lucide="check-circle" class="w-5 h-5"></i> ¡TRÁMITE ENVIADO CON ÉXITO!`;
                btn.classList.remove('bg-forenseNavy', 'hover:bg-slate-800');
                btn.classList.add('bg-emerald-600', 'hover:bg-emerald-500');
                lucide.createIcons();
                
                alert("¡Simulación Exitosa!\n\nEn la etapa final conectaremos esto a Supabase. \nLos datos viajarán a la tabla 'remcycj_solicitudes' y las fotos se subirán al bucket 'remcycj-documentos'.\n\nEl Asesor (Cristian) ya podrá ver este trámite en su Panel Interno.");
                
                setTimeout(() => {
                    document.getElementById('form-publico-adhesion').reset();
                    asignarCategoriaPublica();
                    document.getElementById('file-name-frente').innerText = 'Clic para subir';
                    document.getElementById('file-name-dorso').innerText = 'Clic para subir';
                    document.getElementById('file-name-diploma').innerText = 'Archivo a intervenir';
                    
                    btn.innerHTML = originalHTML;
                    btn.disabled = false;
                    btn.classList.remove('opacity-80', 'cursor-not-allowed', 'bg-emerald-600', 'hover:bg-emerald-500');
                    btn.classList.add('bg-forenseNavy', 'hover:bg-slate-800');
                    lucide.createIcons();
                }, 3000);

            }, 2000);
        }
    </script>
</body>
</html>
