<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Verificador Oficial · RENMCYCF</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Montserrat:wght@700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = { theme: { extend: { colors: { forenseNavy: '#0a1128', forenseGold: '#d4af37', forenseBlue: '#1e3a8a', forenseLight: '#f8fafc' }, fontFamily: { sans: ['Inter', 'sans-serif'], title: ['Montserrat', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] } } } }
    </script>
    <style>
        body { background: #e2e8f0; scroll-behavior: smooth; }
        .loader-spin { animation: spin 1s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .fade-in { animation: fadeIn 0.5s ease-out forwards; opacity: 0; transform: translateY(10px); }
        @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
        .foto-container { width: 80px; height: 80px; background: #ffffff; border-radius: 50%; overflow: hidden; display: flex; align-items: center; justify-content: center; border: 3px solid #d4af37; box-shadow: 0 4px 15px rgba(0,0,0,0.1); flex-shrink: 0; }
        .foto-container img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(10%) contrast(1.05); mix-blend-mode: multiply; }
        .data-row { border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 12px; }
        .data-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4">

    <!-- LOADER -->
    <div id="loader" class="flex flex-col items-center text-center">
        <div class="w-16 h-16 border-4 border-slate-300 border-t-forenseNavy rounded-full loader-spin mb-6"></div>
        <p class="text-forenseNavy font-black text-sm tracking-widest animate-pulse font-title">CONSULTANDO LEDGER...</p>
        <p class="text-slate-500 text-xs mt-2 font-mono">Verificando firma criptográfica e identidad</p>
    </div>

    <!-- ÉXITO -->
    <div id="success-screen" class="hidden w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden border-t-8 border-emerald-500 fade-in relative mb-10">
        <div class="bg-forenseNavy p-6 text-center border-b-4 border-forenseGold relative">
            <div class="w-16 h-16 bg-white text-emerald-500 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg border-2 border-emerald-100 relative z-10"><i data-lucide="check-circle" class="w-8 h-8"></i></div>
            <h1 class="text-xl font-black text-white font-title tracking-wide relative z-10">CREDENCIAL VIGENTE</h1>
            <p class="text-[10px] font-bold text-forenseGold uppercase tracking-widest mt-1 relative z-10">Auditoría Aprobada</p>
        </div>
        <div class="bg-slate-100 py-2.5 px-4 text-center border-b border-slate-200">
            <p class="text-[9px] font-black text-slate-600 uppercase tracking-[0.15em] leading-relaxed">Registro Nacional de Matriculados en Criminalística y Ciencias Forenses</p>
        </div>

        <div class="p-6 md:p-8 relative">
            <div class="flex items-center gap-5 mb-6">
                <div class="foto-container bg-white"><img id="val-foto" src="https://ui-avatars.com/api/?name=U+S&background=0a1128&color=fff" alt="Foto"></div>
                <div class="flex-1">
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mb-1">Titular</p>
                    <h2 class="text-xl font-black text-forenseNavy leading-none mb-1 font-title" id="val-nombre">---</h2>
                    <p class="text-xs font-mono text-slate-500 bg-slate-100 inline-block px-2 py-1 rounded border border-slate-200 mt-1" id="val-dni">DNI: ---</p>
                </div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm mb-6">
                <div class="data-row flex gap-3"><i data-lucide="graduation-cap" class="text-forenseGold w-5 h-5 mt-0.5"></i><div class="flex-1"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Profesión / Título</p><p class="text-sm font-bold text-slate-800 leading-snug mt-0.5" id="val-profesion">---</p></div></div>
                <div class="data-row flex gap-3"><i data-lucide="layers" class="text-forenseGold w-5 h-5 mt-0.5"></i><div class="flex-1 flex justify-between items-center"><div><p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Categoría Asignada</p><p class="text-sm font-bold text-slate-600 mt-0.5" id="val-cat-desc">---</p></div><span id="val-cat-badge" class="bg-forenseNavy text-white font-black text-lg px-3 py-1 rounded-lg border border-forenseGold shadow-sm">--</span></div></div>
                <div class="data-row flex gap-3"><i data-lucide="hash" class="text-forenseGold w-5 h-5 mt-0.5"></i><div class="flex-1"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Matrícula Oficial</p><p class="text-xl font-black text-forenseNavy tracking-tight mt-0.5" id="val-matricula">---</p></div></div>
            </div>
            <div class="flex justify-between items-center bg-emerald-50 border border-emerald-100 p-4 rounded-xl mb-6">
                <div><p class="text-[10px] text-emerald-600 font-bold uppercase tracking-wider">Estado Legal</p><p class="text-sm font-black text-emerald-700">ACTIVO / HABILITADO</p></div>
                <div class="text-right"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Vencimiento</p><p class="text-sm font-bold text-slate-700 font-mono" id="val-vencimiento">---</p></div>
            </div>
            <div class="w-full">
                <p class="text-[10px] text-slate-400 font-bold uppercase mb-1.5 flex items-center gap-1"><i data-lucide="shield" class="w-3 h-3"></i> Sello Criptográfico (TXID)</p>
                <div class="bg-slate-900 text-emerald-400 p-3.5 rounded-xl text-[10px] font-mono break-all leading-relaxed shadow-inner border border-slate-700 select-all" id="val-hash">---</div>
            </div>
        </div>
        <div class="bg-slate-50 p-4 text-center border-t border-slate-200 flex flex-col items-center justify-center gap-2">
            <div class="flex items-center gap-1 text-slate-400"><i data-lucide="lock" class="w-3 h-3"></i><span class="text-[9px] font-bold uppercase tracking-widest">Validación Segura</span></div>
            <p class="text-[10px] text-slate-500 leading-tight max-w-xs">La alteración o falsificación de este documento digital constituye delito penado por las leyes vigentes.</p>
        </div>
    </div>

    <!-- ERROR Y SUSPENDIDO (ESTRUCTURA BÁSICA) -->
    <div id="error-screen" class="hidden w-full max-w-md bg-white rounded-2xl shadow-xl p-8 text-center fade-in border-t-8 border-red-600">
        <div class="w-20 h-20 bg-red-100 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6"><i data-lucide="x-circle" class="w-10 h-10"></i></div>
        <h1 class="text-2xl font-black text-slate-800 mb-2">No Encontrado</h1>
        <p class="text-slate-500 text-sm" id="error-msg">La matrícula solicitada no existe o fue dada de baja.</p>
    </div>

    <script>
        lucide.createIcons();
        const PROJECT_URL = 'https://hiirhuohxpzsphlduypo.supabase.co';
        const PUBLIC_KEY  = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhpaXJodW9oeHB6c3BobGR1eXBvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQyOTgyMTAsImV4cCI6MjA5OTg3NDIxMH0.qvEaRyo0vbnaW9hiX4bXhtRdMkW7n9mDMrApKBRmbhE';
        const db = supabase.createClient(PROJECT_URL, PUBLIC_KEY);

        async function validarProfesional() {
            const params = new URLSearchParams(window.location.search);
            const matQuery = params.get('mat');
            
            if (!matQuery) {
                mostrarError("URL Inválida. Escanee el código QR correctamente.");
                return;
            }

            try {
                // Consultar a Supabase por la matrícula exacta
                const { data: padron, error } = await db.from('renmcycf_padron').select('*').eq('matricula_oficial', matQuery).maybeSingle();

                if (error || !padron) throw new Error("La matrícula solicitada no se encuentra en el Padrón Oficial.");

                // Lógica de estados
                const hoy = new Date();
                const vence = new Date(padron.fecha_vencimiento);

                document.getElementById('loader').classList.add('hidden');

                if (padron.estado_legal === 'SUSPENDIDO') {
                    mostrarError("MATRÍCULA SUSPENDIDA. Inhabilitado para el ejercicio.");
                    return;
                }
                
                if (hoy > vence) {
                    mostrarError(`CERTIFICACIÓN VENCIDA. Expiró el ${vence.toLocaleDateString('es-AR')}.`);
                    return;
                }

                // Inyección de Datos Exitosos
                document.getElementById('success-screen').classList.remove('hidden');
                document.getElementById('val-nombre').innerText = `${padron.nombres} ${padron.apellidos}`;
                document.getElementById('val-dni').innerText = `DNI: ${new Intl.NumberFormat('es-AR').format(padron.dni)}`;
                document.getElementById('val-profesion').innerText = padron.profesion;
                document.getElementById('val-cat-badge').innerText = padron.categoria;
                document.getElementById('val-cat-desc').innerText = padron.categoria === 'A1' ? 'Universitario' : (padron.categoria === 'A2' ? 'Técnico' : 'Auxiliar');
                document.getElementById('val-matricula').innerText = padron.matricula_oficial;
                document.getElementById('val-vencimiento').innerText = vence.toLocaleDateString('es-AR');
                document.getElementById('val-hash').innerText = padron.blockchain_txid;
                
                if(padron.foto_perfil_url) document.getElementById('val-foto').src = padron.foto_perfil_url;

            } catch (err) {
                mostrarError(err.message);
            }
        }

        function mostrarError(msg) {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('error-screen').classList.remove('hidden');
            document.getElementById('error-msg').innerText = msg;
        }

        window.addEventListener('DOMContentLoaded', validarProfesional);
    </script>
</body>
</html>
